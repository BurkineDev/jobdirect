# ============================================================================
# JobDirect — Variables d'environnement
# Copiez ce fichier en « .env.local » et remplissez les valeurs.
# (.env.local est ignoré par git — ne jamais committer de vraies clés.)
#
# Architecture : l'application n'utilise QUE la clé publique. La sécurité
# repose sur la RLS Supabase (voir supabase/schema.sql). Aucune clé secrète
# « service role » n'est requise.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
# Dashboard Supabase > Project Settings > Data API (URL)
#                     > Project Settings > API Keys (clé publique / anon)

# URL du projet — ex : https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Clé publique « anon » (ou « publishable ») — sûre à exposer côté client.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Administration ---------------------------------------------------------
# Courriels autorisés à accéder à /admin (séparés par des virgules).
# Chaque admin doit AUSSI exister dans Supabase Auth et dans la table
# public.admins (voir README).
ADMIN_EMAILS=admin@jobdirect.ca
