# ============================================================================
# JobDirect — Variables d'environnement
# Copiez ce fichier en « .env.local » et remplissez les valeurs.
# (.env.local est ignoré par git — ne jamais committer de vraies clés.)
# ============================================================================

# --- Supabase ---------------------------------------------------------------
# Dashboard Supabase > Project Settings > Data API (URL)
#                     > Project Settings > API Keys

# URL du projet (publique) — ex : https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Clé publique « anon » (publique, utilisée par le navigateur et l'auth admin)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé secrète « service role » — SERVEUR UNIQUEMENT.
# Contourne RLS : ne JAMAIS l'exposer côté client / ne pas préfixer NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --- Administration ---------------------------------------------------------
# Adresses courriel autorisées à accéder à /admin (séparées par des virgules).
# Ces utilisateurs doivent aussi exister dans Supabase Auth (voir README).
ADMIN_EMAILS=admin@jobdirect.ca
